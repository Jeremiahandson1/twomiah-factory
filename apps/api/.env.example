# =============================================================================
# Twomiah Factory API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Variables marked [REQUIRED] must be set for the API to function.
# Variables marked [OPTIONAL] enable additional features when set.
# =============================================================================

# -----------------------------------------------------------------------------
# Core / Runtime
# -----------------------------------------------------------------------------

# [OPTIONAL] Node environment — "production" or "development" (default: development)
NODE_ENV=development

# [OPTIONAL] Port the API listens on (default: 3001)
PORT=3001

# [REQUIRED] URL of the Platform frontend — used for CORS and redirects
PLATFORM_URL=http://localhost:5173

# [OPTIONAL] Public URL of this API — used for QBWC .qwc file generation and cron
# Falls back to RENDER_EXTERNAL_URL, then auto-detected from request URL
# API_URL=https://twomiah-factory-api.onrender.com

# [OPTIONAL] Render-injected external URL — automatic on Render, fallback for API_URL
# RENDER_EXTERNAL_URL=https://twomiah-factory-api.onrender.com

# [REQUIRED] Secret for authenticating cron job requests
CRON_SECRET=generate-a-random-secret-here

# -----------------------------------------------------------------------------
# Supabase (Factory Database)
# -----------------------------------------------------------------------------

# [REQUIRED] Supabase project URL for the factory database
SUPABASE_URL=https://your-project.supabase.co

# [REQUIRED] Supabase service role key — full access to factory database
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# [OPTIONAL] Supabase management API key — for creating dedicated tenant Supabase projects
# SUPABASE_MANAGEMENT_API_KEY=sbp_...

# [OPTIONAL] Supabase organization ID — required with SUPABASE_MANAGEMENT_API_KEY for DB creation
# SUPABASE_ORG_ID=your-supabase-org-id

# -----------------------------------------------------------------------------
# GitHub (Code Deployment)
# -----------------------------------------------------------------------------

# [REQUIRED for deploy] GitHub personal access token — repo push access
GITHUB_TOKEN=ghp_...

# [REQUIRED for deploy] GitHub organization name — repos are created under this org
GITHUB_ORG=your-github-org

# [OPTIONAL] GitHub username — fallback repo owner when GITHUB_ORG is unavailable
GITHUB_USER=your-github-username

# -----------------------------------------------------------------------------
# Render (Hosting)
# -----------------------------------------------------------------------------

# [REQUIRED for deploy] Render API key
RENDER_API_KEY=rnd_...

# [REQUIRED for deploy] Render team/owner ID — services are created under this owner
RENDER_OWNER_ID=tea-...

# [OPTIONAL] Render project environment ID — groups deployed services under Twomiah project
# RENDER_PROJECT_ENV_ID=prj-...

# -----------------------------------------------------------------------------
# AI / Anthropic
# -----------------------------------------------------------------------------

# [OPTIONAL] Anthropic API key — enables AI content generation for tenants
ANTHROPIC_API_KEY=sk-ant-...

# [OPTIONAL] Claude model override (default: claude-sonnet-4-20250514)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# -----------------------------------------------------------------------------
# Factory Paths
# -----------------------------------------------------------------------------

# [OPTIONAL] Path to template source directory (default: ../../templates)
# FACTORY_TEMPLATES_DIR=../../templates

# [OPTIONAL] Path to generated output directory (default: ../../generated)
# FACTORY_OUTPUT_DIR=../../generated

# -----------------------------------------------------------------------------
# Storage (File Uploads)
# -----------------------------------------------------------------------------

# [OPTIONAL] Storage backend — "s3" for cloud storage, "local" for disk (default: local)
# STORAGE_BACKEND=s3

# --- Cloudflare R2 (preferred cloud storage) ---

# [OPTIONAL] Cloudflare R2 account ID — triggers R2 mode when set with S3 backend
# R2_ACCOUNT_ID=your-account-id

# [OPTIONAL] R2 access key ID
# R2_ACCESS_KEY_ID=your-r2-access-key

# [OPTIONAL] R2 secret access key
# R2_SECRET_ACCESS_KEY=your-r2-secret-key

# [OPTIONAL] R2 bucket name
# R2_BUCKET_NAME=your-bucket-name

# [OPTIONAL] Cloudflare API token — used for R2 bucket creation during tenant deploy
# CLOUDFLARE_API_TOKEN=your-cloudflare-token

# --- AWS S3 (alternative cloud storage) ---

# [OPTIONAL] AWS region (default: us-east-1)
# AWS_REGION=us-east-1

# [OPTIONAL] AWS access key ID
# AWS_ACCESS_KEY_ID=your-aws-access-key

# [OPTIONAL] AWS secret access key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# [OPTIONAL] S3 bucket name
# S3_BUCKET_NAME=your-s3-bucket

# -----------------------------------------------------------------------------
# Stripe (Billing)
# -----------------------------------------------------------------------------

# [OPTIONAL] Stripe secret key — enables billing features
# STRIPE_SECRET_KEY=sk_...

# [OPTIONAL] Stripe publishable key — sent to frontend for checkout
# STRIPE_PUBLISHABLE_KEY=pk_...

# [OPTIONAL] Stripe webhook signing secret for factory billing events
# STRIPE_FACTORY_WEBHOOK_SECRET=whsec_...

# [OPTIONAL] Stripe webhook signing secret — fallback name for STRIPE_FACTORY_WEBHOOK_SECRET
# STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# Email (SendGrid)
# -----------------------------------------------------------------------------

# [OPTIONAL] SendGrid API key — enables email notifications
# SENDGRID_API_KEY=SG.xxxxx

# [OPTIONAL] From address for factory emails (default: noreply@twomiah.app)
# FACTORY_FROM_EMAIL=noreply@twomiah.app

# -----------------------------------------------------------------------------
# Vision / Exterior Visualizer
# -----------------------------------------------------------------------------

# [OPTIONAL] Vision Supabase project URL — auto-registers tenants for visualizer during deploy
# VISION_SUPABASE_URL=https://your-vision-project.supabase.co

# [OPTIONAL] Vision Supabase service role key
# VISION_SUPABASE_SERVICE_KEY=your-service-role-key

# [OPTIONAL] Shared Vision service URL — injected into tenant env (default: https://home-visualizer.onrender.com)
# TWOMIAH_VISION_URL=https://home-visualizer.onrender.com

# -----------------------------------------------------------------------------
# Twomiah Ads
# -----------------------------------------------------------------------------

# [OPTIONAL] Ads service URL — injected into tenant env (default: https://twomiah-ads.onrender.com)
# TWOMIAH_ADS_URL=https://twomiah-ads.onrender.com

# [OPTIONAL] Webhook secret for ads service callbacks (default: twomiah_factory_secret_2026)
# ADS_WEBHOOK_SECRET=twomiah_factory_secret_2026

# -----------------------------------------------------------------------------
# QuickBooks Desktop (QBWC)
# -----------------------------------------------------------------------------

# [OPTIONAL] QBWC username — used in .qwc file and authentication (default: twomiah)
# QBWC_USERNAME=twomiah

# [OPTIONAL] QBWC password — required to enable QuickBooks Desktop integration
# QBWC_PASSWORD=

# [OPTIONAL] QuickBooks company file path (default: currently open file)
# QBWC_COMPANY_FILE=

# -----------------------------------------------------------------------------
# QuickBooks Online (OAuth)
# -----------------------------------------------------------------------------

# [OPTIONAL] QuickBooks Online OAuth client ID
# QBO_CLIENT_ID=your-qbo-client-id

# [OPTIONAL] QuickBooks Online OAuth client secret
# QBO_CLIENT_SECRET=your-qbo-client-secret
