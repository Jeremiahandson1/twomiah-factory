<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Age Verification | {{COMPANY_NAME}}</title>
  <meta name="robots" content="noindex, nofollow">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles/animations.css">
  <link rel="stylesheet" href="/styles/effects.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Montserrat', sans-serif;
      background: #0a0f0d;
      color: #fff;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    /* Aurora background */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse at 20% 50%, rgba(15, 76, 46, 0.5) 0%, transparent 55%),
        radial-gradient(ellipse at 80% 20%, rgba(26, 107, 60, 0.4) 0%, transparent 50%),
        radial-gradient(ellipse at 40% 80%, rgba(45, 24, 84, 0.3) 0%, transparent 50%),
        radial-gradient(ellipse at 70% 60%, rgba(13, 61, 43, 0.3) 0%, transparent 45%);
      animation: aurora-shift 20s ease-in-out infinite alternate;
      pointer-events: none;
    }
    @keyframes aurora-shift {
      0% { transform: translate(0, 0) rotate(0deg); filter: hue-rotate(0deg); }
      33% { transform: translate(5%, -3%) rotate(2deg); filter: hue-rotate(15deg); }
      66% { transform: translate(-3%, 5%) rotate(-1deg); filter: hue-rotate(-10deg); }
      100% { transform: translate(2%, 2%) rotate(1deg); filter: hue-rotate(20deg); }
    }

    @media (max-width: 480px) {
      .age-gate-immersive .ag-buttons { flex-direction: column; }
      .age-gate-immersive .ag-btn { width: 100%; }
    }
  </style>
</head>
<body>
  <div class="age-gate-immersive">
    <!-- Floating particles -->
    <div class="ag-particles"></div>

    <!-- Content with blur-to-focus reveal -->
    <div class="ag-content">
      <% if (typeof logoUrl !== 'undefined' && logoUrl) { %>
        <div style="margin-bottom:24px;">
          <img src="<%= logoUrl %>" alt="{{COMPANY_NAME}}" style="max-height:70px;width:auto;filter:brightness(2);" onerror="this.style.display='none'">
        </div>
      <% } %>

      <h1 class="ag-title">Are you 21 or older?</h1>
      <p class="ag-subtitle">You must be at least 21 to enter this site.</p>

      <div class="ag-buttons">
        <form method="POST" action="/age-verify" style="display:inline">
          <input type="hidden" name="next" value="<%= typeof next !== 'undefined' ? next : '/' %>">
          <button type="submit" class="ag-btn ag-btn-yes">Yes, I'm 21+</button>
        </form>
        <a href="https://www.google.com" class="ag-btn ag-btn-no">No, I'm Not</a>
      </div>

      <div class="ag-legal">
        By entering, you agree to our <a href="/p/terms" style="color:rgba(255,255,255,0.5);text-decoration:underline;">Terms</a> &amp; <a href="/p/privacy" style="color:rgba(255,255,255,0.5);text-decoration:underline;">Privacy Policy</a>.
        Cannabis products are for adults 21+ only. Keep out of reach of children.
      </div>
    </div>
  </div>

  <script>
    // Age gate floating particles
    (function() {
      var container = document.querySelector('.ag-particles');
      if (!container) return;
      for (var i = 0; i < 35; i++) {
        var p = document.createElement('div');
        p.className = 'particle';
        p.style.left = Math.random() * 100 + '%';
        p.style.width = p.style.height = (Math.random() * 6 + 2) + 'px';
        p.style.background = 'rgba(34, 197, 94, ' + (Math.random() * 0.4 + 0.1) + ')';
        p.style.animationDuration = (Math.random() * 15 + 10) + 's';
        p.style.animationDelay = (Math.random() * 10) + 's';
        container.appendChild(p);
      }
    })();
  </script>
</body>
</html>
