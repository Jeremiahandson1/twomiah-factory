<%
// Extract data with fallbacks
const hero = (typeof homepage !== 'undefined' && homepage && homepage.hero) ? homepage.hero : {};
const trustBadges = (typeof homepage !== 'undefined' && homepage && homepage.trustBadges) ? homepage.trustBadges.filter(b => b.enabled) : [];
const ctaSection = (typeof homepage !== 'undefined' && homepage && homepage.ctaSection) ? homepage.ctaSection : {};
const serviceAreas = (typeof homepage !== 'undefined' && homepage && homepage.serviceAreas) ? homepage.serviceAreas : ['{{CITY}}', '{{NEARBY_CITY_4}}', '{{NEARBY_CITY_1}}', '{{NEARBY_CITY_2}}', '{{NEARBY_CITY_3}}'];
const businessHours = (typeof homepage !== 'undefined' && homepage && homepage.businessHours) ? homepage.businessHours : {};

// Settings with fallbacks
const phone = (typeof settings !== 'undefined' && settings && settings.phone) ? settings.phone : '{{COMPANY_PHONE}}';
const email = (typeof settings !== 'undefined' && settings && settings.email) ? settings.email : '{{COMPANY_EMAIL}}';
const address = (typeof settings !== 'undefined' && settings && settings.address) ? settings.address : '{{COMPANY_ADDRESS}}';
const city = (typeof settings !== 'undefined' && settings && settings.city) ? settings.city : '{{CITY}}';
const state = (typeof settings !== 'undefined' && settings && settings.state) ? settings.state : '{{STATE}}';
const zip = (typeof settings !== 'undefined' && settings && settings.zip) ? settings.zip : '{{ZIP}}';
const phoneRaw = phone.replace(/\D/g, '');

// Function to get image URL
function getImageUrl(p) {
  if (!p) return '';
  if (p.startsWith('http')) return p;
  if (p.startsWith('/')) return p;
  return '/uploads/' + p;
}
%>

<div class="home-page">
  <!-- Age Gate Overlay (first visit check) -->
  <div id="ageGateOverlay" class="age-overlay" style="display:none">
    <div class="age-overlay-card">
      <h2>Are you 21 or older?</h2>
      <p>You must be 21+ to browse this website.</p>
      <div class="age-overlay-buttons">
        <button id="ageYesBtn" class="btn btn-primary btn-lg">Yes, I'm 21+</button>
        <a href="https://www.google.com" class="btn btn-outline btn-lg">No</a>
      </div>
    </div>
  </div>

  <!-- Hero Section — Fluid Sim + Shader BG + Kinetic Type -->
  <section
    class="hero-video hero-enhanced hero-gradient-morph <%= hero.image ? 'hero-animated' : '' %>"
    style="--hero-speed: <%= hero.animationSpeed || 10 %>s"
  >
    <!-- WebGL Fluid Simulation Layer -->
    <div class="fluid-canvas-wrap"></div>

    <% if (hero.image) { %>
      <div
        class="hero-bg animation-<%= hero.animation || 'none' %>"
        style="background-image: url(<%= getImageUrl(hero.image) %>)"
      ></div>
      <div class="hero-overlay"></div>
    <% } else { %>
      <div class="hero-video-bg">
        <div class="video-placeholder"></div>
        <div class="hero-overlay"></div>
      </div>
    <% } %>
    <div class="hero-video-content <%= hero.image ? 'hero-content' : '' %>" data-depth="0.03">
      <h1 class="kinetic-text variable-font-hero"><%= hero.title || '{{COMPANY_NAME}}' %></h1>
      <h2><%= hero.subtitle || 'Premium Cannabis Dispensary' %></h2>
      <div class="hero-line"></div>
      <p class="hero-tagline"><strong><%= hero.tagline || 'CURATED CANNABIS FOR EVERY LIFESTYLE' %></strong></p>
      <p class="hero-awards"><%= hero.description || 'Quality products, knowledgeable staff, and a welcoming experience' %></p>
      <div class="hero-buttons">
        <a href="<%= hero.primaryButtonLink || '/menu' %>" class="btn btn-primary btn-lg magnetic-btn">
          <span class="btn-text"><%= hero.primaryButtonText || 'Browse Menu' %></span>
        </a>
        <a href="<%= hero.secondaryButtonLink || '/order' %>" class="btn btn-outline-light btn-lg magnetic-btn">
          <span class="btn-text"><%= hero.secondaryButtonText || 'Order Online' %></span>
        </a>
      </div>
    </div>
  </section>

  <!-- 21+ Notice Bar -->
  <div class="age-notice-bar">
    <div class="container">
      <span>&#9888; Adults 21+ Only &mdash; Valid government-issued ID required for all purchases.</span>
    </div>
  </div>

  <!-- Stats Counter Section -->
  <section class="section-aurora" style="padding:60px 0;">
    <div class="container">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:32px;text-align:center;" class="stagger-grid">
        <div class="glass-card scroll-reveal" style="padding:32px 20px;">
          <div class="stat-counter" data-target="1000" data-suffix="+">0</div>
          <div style="font-size:0.9rem;font-weight:600;margin-top:8px;color:#666;">Products Available</div>
        </div>
        <div class="glass-card scroll-reveal" style="padding:32px 20px;">
          <div class="stat-counter" data-target="4.9" data-decimals="1" data-suffix="★">0</div>
          <div style="font-size:0.9rem;font-weight:600;margin-top:8px;color:#666;">Customer Rating</div>
        </div>
        <div class="glass-card scroll-reveal" style="padding:32px 20px;">
          <div class="stat-counter" data-target="15000" data-suffix="+">0</div>
          <div style="font-size:0.9rem;font-weight:600;margin-top:8px;color:#666;">Happy Customers</div>
        </div>
        <div class="glass-card scroll-reveal" style="padding:32px 20px;">
          <div class="stat-counter" data-target="5" data-suffix=" Years">0</div>
          <div style="font-size:0.9rem;font-weight:600;margin-top:8px;color:#666;">Serving the Community</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Store Hours Section -->
  <section class="hours-section divider-wave">
    <div class="container">
      <div class="hours-grid">
        <div class="hours-info scroll-slide-left">
          <h2>Visit Us</h2>
          <div class="hours-table">
            <% if (businessHours.monday && !businessHours.monday.closed) { %>
              <div class="hours-row">
                <span>Monday - Friday</span>
                <span><%= businessHours.monday.open %> - <%= businessHours.monday.close %></span>
              </div>
            <% } else { %>
              <div class="hours-row">
                <span>Monday - Friday</span>
                <span>9am - 9pm</span>
              </div>
            <% } %>
            <% if (businessHours.saturday && !businessHours.saturday.closed) { %>
              <div class="hours-row">
                <span>Saturday</span>
                <span><%= businessHours.saturday.open %><% if (businessHours.saturday.close) { %> - <%= businessHours.saturday.close %><% } %></span>
              </div>
            <% } else { %>
              <div class="hours-row">
                <span>Saturday</span>
                <span>9am - 10pm</span>
              </div>
            <% } %>
            <% if (businessHours.sunday && !businessHours.sunday.closed) { %>
              <div class="hours-row">
                <span>Sunday</span>
                <span><%= businessHours.sunday.open %><% if (businessHours.sunday.close) { %> - <%= businessHours.sunday.close %><% } %></span>
              </div>
            <% } else { %>
              <div class="hours-row">
                <span>Sunday</span>
                <span>10am - 8pm</span>
              </div>
            <% } %>
          </div>
          <div class="hours-address">
            <p><%= address %></p>
            <p><%= city %>, <%= state %> <%= zip %></p>
            <a href="tel:<%= phoneRaw %>" class="hours-phone"><%= phone %></a>
          </div>
        </div>
        <div class="hours-features scroll-slide-right stagger-grid">
          <div class="feature-badge glass-card hover-glow">
            <span class="feature-icon">&#128666;</span>
            <div>
              <strong>Pickup &amp; Delivery</strong>
              <span>Order ahead, skip the wait</span>
            </div>
          </div>
          <div class="feature-badge glass-card hover-glow">
            <span class="feature-icon">&#127807;</span>
            <div>
              <strong>Lab Tested Products</strong>
              <span>Every product tested for safety</span>
            </div>
          </div>
          <div class="feature-badge glass-card hover-glow">
            <span class="feature-icon">&#11088;</span>
            <div>
              <strong>Loyalty Program</strong>
              <span>Earn points on every purchase</span>
            </div>
          </div>
          <div class="feature-badge glass-card hover-glow">
            <span class="feature-icon">&#128101;</span>
            <div>
              <strong>Expert Budtenders</strong>
              <span>Personalized recommendations</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Products Section -->
  <% if (typeof services !== 'undefined' && services && services.length > 0) { %>
  <section class="featured-section section-aurora glow-border" id="services">
    <div class="container">
      <h2 class="scroll-reveal">Featured Products</h2>
      <div class="services-grid stagger-grid">
        <% services.forEach(function(service) { %>
          <div class="service-card card-lift hover-glow scroll-reveal">
            <div class="service-image">
              <% if (service.image) { %>
                <img
                  src="<%= getImageUrl(service.image) %>"
                  alt="<%= service.title %> at {{COMPANY_NAME}}"
                  loading="lazy"
                  width="800"
                  height="600"
                >
              <% } else { %>
                <span class="service-icon"><%= service.icon || '&#127807;' %></span>
              <% } %>
            </div>
            <div class="service-content">
              <h3><%= service.title %></h3>
              <p><%= service.shortDescription || service.tagline || service.description %></p>
              <% if (service.links && service.links.length > 0) { %>
                <hr>
                <ul class="service-links">
                  <% service.links.forEach(function(link) { %>
                    <li><a href="<%= link.href %>"><%= link.label %></a></li>
                  <% }); %>
                </ul>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
      <div style="text-align: center; margin-top: 2rem;">
        <a href="/menu" class="btn btn-primary btn-lg magnetic-btn"><span class="btn-text">View Full Menu</span></a>
      </div>
    </div>
  </section>
  <% } %>

  <!-- Why Choose Us Section -->
  <section class="why-choose-section shader-bg divider-wave">
    <div class="container">
      <h2 class="scroll-reveal">Why {{CITY}} Chooses {{COMPANY_NAME}}</h2>
      <div class="why-grid stagger-grid">
        <div class="why-item glass-card hover-glow scroll-reveal">
          <div class="why-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>Lab-Tested Quality</h3>
          <p>Every product on our shelves is third-party lab tested for potency, purity, and safety. We only carry brands and cultivators that meet our strict quality standards.</p>
        </div>
        <div class="why-item glass-card hover-glow scroll-reveal">
          <div class="why-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3>Knowledgeable Budtenders</h3>
          <p>Our staff are trained cannabis professionals who can help you find the right product for your needs, whether you are a seasoned consumer or visiting a dispensary for the first time.</p>
        </div>
        <div class="why-item glass-card hover-glow scroll-reveal">
          <div class="why-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3>Locally Rooted</h3>
          <p>We're proud to serve the {{SERVICE_REGION}} community. We support local growers and brands, and give back to the neighborhoods where our customers live.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <% if (typeof testimonials !== 'undefined' && testimonials && testimonials.length > 0) { %>
    <section class="testimonials-section section-aurora">
      <div class="container">
        <h2>What Our Customers Say</h2>
        <div class="testimonial-slider">
          <% testimonials.forEach(function(testimonial, index) { %>
            <div class="testimonial-card <%= index === 0 ? 'active' : '' %>" data-index="<%= index %>">
              <div class="testimonial-content">
                <div class="testimonial-stars">
                  <%= '★'.repeat(testimonial.rating || 5) %>
                </div>
                <blockquote>"<%= testimonial.text %>"</blockquote>
                <div class="testimonial-author">
                  <% if (testimonial.image) { %>
                    <img src="<%= getImageUrl(testimonial.image) %>" alt="<%= testimonial.author %>">
                  <% } %>
                  <div>
                    <strong><%= testimonial.author %></strong>
                    <% if (testimonial.location) { %>
                      <span><%= testimonial.location %></span>
                    <% } %>
                  </div>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
        <% if (testimonials.length > 1) { %>
          <div class="testimonial-dots">
            <% testimonials.forEach(function(_, i) { %>
              <button
                class="<%= i === 0 ? 'active' : '' %>"
                data-index="<%= i %>"
                aria-label="Testimonial <%= i + 1 %>"
              ></button>
            <% }); %>
          </div>
        <% } %>
      </div>
    </section>
  <% } %>

  <!-- Trust Badges -->
  <% if (trustBadges.length > 0) { %>
    <section class="trust-section">
      <div class="container">
        <div class="review-badges">
          <% trustBadges.forEach(function(badge) { %>
            <div class="review-badge">
              <% if (badge.type === 'google') { %>
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                </svg>
              <% } else if (badge.type === 'leafly') { %>
                <span class="badge-text" style="color:#00b368;font-weight:800;">Leafly</span>
              <% } else if (badge.type === 'weedmaps') { %>
                <span class="badge-text" style="color:#00c389;font-weight:800;">WM</span>
              <% } else { %>
                <span class="badge-text">&#10003;</span>
              <% } %>
              <div class="badge-info">
                <span class="stars"><%= badge.label %></span>
                <span class="count"><%= badge.sublabel %></span>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
    </section>
  <% } %>

  <!-- CTA Section -->
  <section
    class="cta-section aurora-bg"
    <% if (ctaSection.backgroundImage) { %>
      style="background-image: url(<%= getImageUrl(ctaSection.backgroundImage) %>)"
    <% } %>
  >
    <div class="container">
      <%
        const ctaTitle = ctaSection.title || 'Premium cannabis,\ndelivered your way.';
        const ctaTitleLines = ctaTitle.split('\n');
      %>
      <h2>
        <% ctaTitleLines.forEach(function(line, i) { %>
          <%= line %><% if (i === 0 && ctaTitleLines.length > 1) { %><br><% } %>
        <% }); %>
      </h2>
      <p><%= ctaSection.description || "Order online for fast pickup or delivery. First-time customers get 15% off their first order." %></p>
      <div class="cta-buttons">
        <a href="<%= ctaSection.primaryButtonLink || '/order' %>" class="btn btn-primary btn-lg magnetic-btn">
          <span class="btn-text"><%= ctaSection.primaryButtonText || 'Order Now' %></span>
        </a>
        <a href="<%= ctaSection.secondaryButtonLink || 'tel:' + phoneRaw %>" class="btn btn-outline btn-lg magnetic-btn">
          <span class="btn-text"><%= ctaSection.secondaryButtonText || 'Call ' + phone %></span>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="home-faq">
    <div class="container">
      <h2>Frequently Asked Questions</h2>
      <div class="home-faq-list">
        <details class="home-faq-item scroll-reveal">
          <summary><strong>What do I need to bring to purchase cannabis?</strong></summary>
          <p>You must be 21 or older and present a valid, unexpired government-issued photo ID (driver's license, state ID, or passport). Temporary or expired IDs are not accepted.</p>
        </details>
        <details class="home-faq-item scroll-reveal">
          <summary><strong>Do you offer delivery?</strong></summary>
          <p>Yes, we offer delivery within the {{SERVICE_REGION}} area. Place your order online and select the delivery option at checkout. Minimum order amounts may apply.</p>
        </details>
        <details class="home-faq-item scroll-reveal">
          <summary><strong>How does the loyalty program work?</strong></summary>
          <p>Sign up for free and earn 1 point per dollar spent. Points can be redeemed for discounts, free products, and exclusive deals. Visit our <a href="/loyalty">loyalty page</a> for full details on tiers and rewards.</p>
        </details>
        <details class="home-faq-item scroll-reveal">
          <summary><strong>Can I order online for pickup?</strong></summary>
          <p>Absolutely! Browse our menu, add items to your cart, and select pickup at checkout. We will have your order ready when you arrive. Most orders are ready in 15-30 minutes.</p>
        </details>
        <details class="home-faq-item scroll-reveal">
          <summary><strong>What forms of payment do you accept?</strong></summary>
          <p>We accept cash and debit cards. An ATM is available on-site. Some products may also be available for purchase via our online ordering system.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section class="contact-section" id="contact">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <h2>Get in Touch</h2>
          <div class="contact-item">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
            <div>
              <strong>Phone</strong>
              <a href="tel:<%= phoneRaw %>"><%= phone %></a>
            </div>
          </div>
          <div class="contact-item">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            <div>
              <strong>Email</strong>
              <a href="mailto:<%= email %>"><%= email %></a>
            </div>
          </div>
          <div class="contact-item">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <div>
              <strong>Address</strong>
              <span><%= address %><br/><%= city %>, <%= state %> <%= zip %></span>
            </div>
          </div>
          <div class="contact-item">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
            <div>
              <strong>Hours</strong>
              <span>
                <% if (businessHours.monday && !businessHours.monday.closed) { %>
                  Mon - Fri: <%= businessHours.monday.open %> - <%= businessHours.monday.close %>
                <% } else { %>
                  Mon - Fri: 9am - 9pm
                <% } %>
                <br/>
                <% if (businessHours.saturday && !businessHours.saturday.closed) { %>
                  Sat: <%= businessHours.saturday.open %><% if (businessHours.saturday.close) { %> - <%= businessHours.saturday.close %><% } %>
                <% } else { %>
                  Sat: 9am - 10pm
                <% } %>
              </span>
            </div>
          </div>

          <div class="service-areas">
            <h3>Serving</h3>
            <p><%= serviceAreas.join(', ') %>, and surrounding communities.</p>
          </div>
        </div>

        <div class="contact-form-container">
          <h2>Send Us a Message</h2>
          <form id="contact-form" method="POST" action="/api/admin/leads">
            <div class="form-row">
              <div class="form-group">
                <label for="name">Name *</label>
                <input type="text" id="name" name="name" required>
              </div>
              <div class="form-group">
                <label for="phone">Phone *</label>
                <input type="tel" id="phone" name="phone" required>
              </div>
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email">
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="4" placeholder="Questions about products, hours, orders..."></textarea>
            </div>
            <div id="form-error" style="display: none; color: #dc2626; background: #fef2f2; padding: 12px 16px; border-radius: 8px; margin-bottom: 8px; font-size: 0.95rem;"></div>
            <button type="submit" class="btn btn-primary btn-lg full-width">
              Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section -->
  <section class="map-section">
    <iframe
      src="https://maps.google.com/maps?q=<%= encodeURIComponent(address + ', ' + city + ', ' + state + ' ' + zip) %>&output=embed"
      allowfullscreen=""
      loading="lazy"
      title="Location Map"
    ></iframe>
  </section>

  <!-- LocalBusiness Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Store",
    "name": "{{COMPANY_NAME}}",
    "image": "{{SITE_URL}}/logo.jpg",
    "url": "{{SITE_URL}}",
    "telephone": "+1<%= phoneRaw %>",
    "email": "<%= email %>",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "<%= address %>",
      "addressLocality": "<%= city %>",
      "addressRegion": "<%= state %>",
      "postalCode": "<%= zip %>",
      "addressCountry": "US"
    },
    "areaServed": [
      <% serviceAreas.forEach(function(area, index) { %>
      {
        "@type": "City",
        "name": "<%= area %>, {{STATE}}"
      }<%= index < serviceAreas.length - 1 ? ',' : '' %>
      <% }); %>
    ],
    "priceRange": "$$",
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": "09:00",
        "closes": "21:00"
      },
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": "Saturday",
        "opens": "09:00",
        "closes": "22:00"
      },
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": "Sunday",
        "opens": "10:00",
        "closes": "20:00"
      }
    ]
    <% if (typeof testimonials !== 'undefined' && testimonials && testimonials.length > 0) { %>
    ,"aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "<%= (testimonials.reduce(function(sum, t) { return sum + (t.rating || 5); }, 0) / testimonials.length).toFixed(1) %>",
      "reviewCount": <%= testimonials.length %>,
      "bestRating": "5",
      "worstRating": "1"
    }
    ,"review": [
      <% testimonials.forEach(function(t, index) { %>
      {
        "@type": "Review",
        "author": {
          "@type": "Person",
          "name": "<%= t.author %>"
        },
        "reviewRating": {
          "@type": "Rating",
          "ratingValue": <%= t.rating || 5 %>,
          "bestRating": "5"
        },
        "reviewBody": "<%= t.text %>"
        <% if (t.createdAt) { %>
        ,"datePublished": "<%= t.createdAt.split('T')[0] %>"
        <% } %>
      }<%= index < testimonials.length - 1 ? ',' : '' %>
      <% }); %>
    ]
    <% } %>
  }
  </script>

