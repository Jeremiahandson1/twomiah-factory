# Server
PORT=5000
NODE_ENV=production

# CORS - your frontend domain
CORS_ORIGIN=https://your-domain.com

# JWT Secret - REQUIRED in production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Tenant slug (for multi-tenant integrations like Vision)
# TENANT_SLUG=your-company-slug

# Vision Visualizer (set by Factory when visualizer add-on is enabled)
# VISION_URL=https://twomiah-vision.onrender.com

# Email notifications are configured in the admin panel:
# Admin > Site Settings > Email Notifications
# You'll need a SendGrid API key: https://sendgrid.com (free tier = 100 emails/day)
