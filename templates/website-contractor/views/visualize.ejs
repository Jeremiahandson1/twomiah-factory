<% const visionUrl = typeof VISION_URL !== 'undefined' ? VISION_URL : '' %>
<% const tenantSlug = typeof TENANT_SLUG !== 'undefined' ? TENANT_SLUG : '' %>
<% const embedSrc = visionUrl + '/embed?tenant=' + encodeURIComponent(tenantSlug) %>

<section class="visualizer-page">
  <div class="visualizer-header">
    <div class="container">
      <h1>Visualize Your Project</h1>
      <p>Upload a photo of your home and see how different materials, colors, and styles will look — before any work begins.</p>
    </div>
  </div>

  <div class="visualizer-embed">
    <iframe
      src="<%= embedSrc %>"
      allow="camera; clipboard-write"
      allowfullscreen
      title="Project Visualizer"
    ></iframe>
  </div>

  <div class="visualizer-footer">
    <div class="container">
      <div class="visualizer-cta">
        <h2>Ready to get started?</h2>
        <p>Like what you see? Request a free estimate and we'll bring your vision to life.</p>
        <div class="visualizer-cta-buttons">
          <a href="/contact" class="btn btn-primary">Request Estimate</a>
          <a href="tel:<%= (typeof settings !== 'undefined' && settings.phone) ? settings.phone.replace(/[^0-9+]/g, '') : '' %>" class="btn btn-outline">
            Call <%= (typeof settings !== 'undefined' && settings.phone) ? settings.phone : '' %>
          </a>
        </div>
      </div>

      <% const allServices = typeof services !== 'undefined' ? services : [] %>
      <% if (allServices.length > 0) { %>
        <div class="visualizer-services">
          <h3>Our Services</h3>
          <div class="visualizer-services-grid">
            <% allServices.slice(0, 8).forEach(function(svc) { %>
              <a href="/services/<%= svc.slug %>" class="visualizer-service-link"><%= svc.name %></a>
            <% }) %>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</section>

<style>
  .visualizer-page {
    display: flex;
    flex-direction: column;
    min-height: calc(100vh - 140px);
  }
  .visualizer-header {
    text-align: center;
    padding: 2.5rem 1rem 1.5rem;
    background: var(--off-white, #f8f9fa);
  }
  .visualizer-header h1 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--heading-color, #1a1a1a);
    margin: 0 0 0.5rem;
  }
  .visualizer-header p {
    color: var(--text-muted, #6b7280);
    font-size: 1.05rem;
    max-width: 600px;
    margin: 0 auto;
  }
  .visualizer-embed {
    flex: 1;
    min-height: 600px;
    position: relative;
    background: #f3f4f6;
  }
  .visualizer-embed iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
  .visualizer-footer {
    padding: 3rem 1rem;
    background: #fff;
  }
  .visualizer-cta {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .visualizer-cta h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
  }
  .visualizer-cta p {
    color: var(--text-muted, #6b7280);
    margin: 0 0 1.25rem;
  }
  .visualizer-cta-buttons {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .visualizer-cta-buttons .btn-outline {
    border: 2px solid var(--primary-color, #2563eb);
    color: var(--primary-color, #2563eb);
    background: transparent;
    padding: 0.6rem 1.5rem;
    border-radius: 6px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }
  .visualizer-cta-buttons .btn-outline:hover {
    background: var(--primary-color, #2563eb);
    color: #fff;
  }
  .visualizer-services {
    text-align: center;
  }
  .visualizer-services h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 1rem;
    color: var(--heading-color, #1a1a1a);
  }
  .visualizer-services-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }
  .visualizer-service-link {
    padding: 0.4rem 1rem;
    border: 1px solid #e5e7eb;
    border-radius: 20px;
    color: var(--text-color, #374151);
    font-size: 0.9rem;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }
  .visualizer-service-link:hover {
    border-color: var(--primary-color, #2563eb);
    color: var(--primary-color, #2563eb);
  }
  @media (max-width: 768px) {
    .visualizer-embed {
      min-height: 500px;
    }
    .visualizer-header h1 {
      font-size: 1.5rem;
    }
  }
</style>
