# HomeCare CRM Backend Environment Variables
#
# On Render: set these in your service's Environment tab or via render.yaml
# DATABASE_URL is injected automatically by Render from the linked database — do NOT set it here

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET="your-jwt-secret-here"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-here"

# ── App ──────────────────────────────────────────────────
NODE_ENV="production"
PORT=10000
FRONTEND_URL="https://your-frontend-domain.com"

# ── Encryption (for SSN, license number, sensitive fields) ──
ENCRYPTION_KEY="your-encryption-key-here"

# ── Twilio (SMS — optional) ──────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ── Email (SendGrid — optional) ──────────────────────────
SENDGRID_API_KEY=""
EMAIL_FROM="noreply@your-domain.com"

# ── Stripe (optional) ────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── Push Notifications / VAPID (optional) ────────────────
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="noreply@your-domain.com"

# ── File Uploads ─────────────────────────────────────────
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

# ── Sandata EVV (Wisconsin Alt EVV Addendum v2.5) ────────
# AGENCY_MEDICAID_ID="1234567890"          # Your agency's WI Medicaid provider ID
# SANDATA_USERNAME=""                       # Sandata API username
# SANDATA_PASSWORD=""                       # Sandata API password
# SANDATA_ENV="uat"                         # "uat" or "production"

# ── Feature Flags ─────────────────────────────────────────
ENABLE_SANDATA_EVV=false
ENABLE_GUSTO=false
ENABLE_WORCS=false
