  @@index([equipmentId])
  @@index([companyId])
}

model JobAssignment {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("JobAssignments", fields: [userId], references: [id])
  role      String?
  createdAt DateTime @default(now())
  @@unique([jobId, userId])
  @@index([jobId])
  @@index([userId])
}

model OauthState {
  id        String   @id @default(cuid())
  state     String   @unique
  provider  String
  companyId String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  @@index([state])
}

model Photo {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  entityType    String?
  entityId      String?
  filename      String
  originalName  String?
  mimeType      String   @default("image/jpeg")
  size          Int?
  width         Int?
  height        Int?
  thumbnailPath String?
  caption       String?
  tags          Json?
  createdAt     DateTime @default(now())
  @@index([companyId])
  @@index([entityType, entityId])
}

model PricebookGoodBetterBest {
  id              String        @id @default(cuid())
  pricebookItemId String
  pricebookItem   PricebookItem @relation(fields: [pricebookItemId], references: [id], onDelete: Cascade)
  tier            String
  name            String?
  description     String?
  price           Decimal       @db.Decimal(12, 2)
  features        Json?
  @@index([pricebookItemId])
}

model PricebookMaterial {
  id              String        @id @default(cuid())
  pricebookItemId String
  pricebookItem   PricebookItem @relation(fields: [pricebookItemId], references: [id], onDelete: Cascade)
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  quantity        Decimal       @default(1) @db.Decimal(10, 4)
  priceOverride   Decimal?      @db.Decimal(12, 2)
  @@index([pricebookItemId])
}

model Product {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  description String?
  sku         String?
  price       Decimal  @default(0) @db.Decimal(12, 2)
  category    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([companyId])
}

model ProjectBaseline {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name          String
  taskSnapshots Json?
  createdAt     DateTime @default(now())
  @@index([projectId])
}

model ProjectSelection {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  categoryId  String?
  category    SelectionCategory? @relation(fields: [categoryId], references: [id])
  name        String
  description String?
  location    String?
  allowance   Decimal? @db.Decimal(12, 2)
  status      String   @default("pending")
  selectedOptionId String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([projectId])
}

model ProjectTask {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      ProjectTask?  @relation("ProjectTaskChildren", fields: [parentId], references: [id])
  children    ProjectTask[] @relation("ProjectTaskChildren")
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  duration    Int?
  progress    Int       @default(0)
  assignedToId String?
  assignedTo  User?     @relation("ProjectTaskAssigned", fields: [assignedToId], references: [id])
  status      String    @default("not_started")
  dependencies TaskDependency[] @relation("SuccessorTask")
  predecessors TaskDependency[] @relation("PredecessorTask")
  calculatedMaterials TakeoffCalculatedMaterial[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  @@index([projectId])
  @@index([parentId])
}

model TaskDependency {
  id            String      @id @default(cuid())
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectId     String
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  predecessorId String
  predecessor   ProjectTask @relation("PredecessorTask", fields: [predecessorId], references: [id], onDelete: Cascade)
  successorId   String
  successor     ProjectTask @relation("SuccessorTask", fields: [successorId], references: [id], onDelete: Cascade)
  type          String      @default("finish_to_start")
  lagDays       Int         @default(0)
  createdAt     DateTime    @default(now())
  @@index([projectId])
}

model SelectionOption {
  id           String    @id @default(cuid())
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  categoryId   String?
  category     SelectionCategory? @relation(fields: [categoryId], references: [id])
  name         String
  description  String?
  manufacturer String?
  model        String?
  sku          String?
  price        Decimal   @default(0) @db.Decimal(12, 2)
  imageUrl     String?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  @@index([companyId])
  @@index([categoryId])
}

model SmsAutoResponder {
  id             String   @id @default(cuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name           String
  trigger        String
  keywords       Json?
  message        String
  afterHoursOnly Boolean  @default(false)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@index([companyId])
}

model TakeoffCalculatedMaterial {
  id             String      @id @default(cuid())
  itemId         String
  item           ProjectTask @relation(fields: [itemId], references: [id], onDelete: Cascade)
  materialName   String
  unit           String
  baseQuantity   Decimal     @db.Decimal(12, 4)
  wasteQuantity  Decimal     @default(0) @db.Decimal(12, 4)
  totalQuantity  Decimal     @db.Decimal(12, 4)
  unitCost       Decimal     @default(0) @db.Decimal(12, 2)
  totalCost      Decimal     @default(0) @db.Decimal(12, 2)
  createdAt      DateTime    @default(now())
  @@index([itemId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  @@index([userId])
}
