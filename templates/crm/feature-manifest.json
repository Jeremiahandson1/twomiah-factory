    },
    "frontend": {
      "pages": ["LoginPage.tsx", "RegisterPage.tsx", "ForgotPasswordPage.tsx", "ResetPasswordPage.tsx", "DashboardPage.tsx", "ContactsPage.tsx", "JobsPage.tsx", "QuotesPage.tsx", "InvoicesPage.tsx", "SchedulePage.tsx", "TeamPage.tsx", "SettingsPage.tsx"],
