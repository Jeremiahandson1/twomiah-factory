    },
    "sidebar": [
      { "id": "dashboard", "label": "Dashboard", "icon": "LayoutDashboard", "path": "/" },
      { "id": "contacts", "label": "Contacts", "icon": "Users", "path": "/contacts" },
      { "id": "jobs", "label": "Jobs", "icon": "Briefcase", "path": "/jobs" },
      { "id": "quotes", "label": "Quotes", "icon": "FileText", "path": "/quotes" },
