{
  "_comment": "CRM Feature Manifest — Maps feature IDs from features.ts to their implementation files and sidebar nav entries. The CRM uses runtime feature gating (FeatureGate middleware + component), so the generator copies the full codebase and configures enabledFeatures in the company seed.",

  "core": {
    "_comment": "Always included — cannot be disabled",
    "features": ["contacts", "jobs", "quotes", "invoices", "scheduling", "team", "dashboard"],
    "backend": {
      "routes": ["auth.ts", "contacts.ts", "jobs.ts", "quotes.ts", "invoices.ts", "time.ts", "team.ts", "company.ts", "dashboard.ts", "projects.ts", "expenses.ts", "documents.ts", "payroll.ts", "webhooks.ts", "agencyAdmin.ts", "audit.ts", "billing.ts", "bulk.ts", "comments.ts", "export.ts", "gapFeatures.ts", "import.ts", "integrations.ts", "migration.ts", "portal-messages.ts", "push.ts", "search.ts", "support.ts", "tasks.ts", "weather.ts"],
